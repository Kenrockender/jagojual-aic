# mock  = jalan tanpa GPU/model (default; ini yang dipakai panitia untuk cross-check)
# local = pakai LLM lokal + adapter LoRA hasil fine-tune
JAGOJUAL_MODE=mock
JAGOJUAL_BASE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
JAGOJUAL_ADAPTER_PATH=../model/checkpoints
JAGOJUAL_CORS_ORIGINS=http://localhost:3000

# --- hanya berpengaruh saat JAGOJUAL_MODE=local ---
# 4-bit wajib untuk GPU 6GB; matikan hanya kalau VRAM lega.
JAGOJUAL_LOAD_4BIT=true
# Hanya untuk mode Pelanggan. Mode Pelatih selalu greedy agar penilaian atas
# percakapan yang sama tidak berubah saat demo diulang.
JAGOJUAL_TEMPERATURE=0.8
JAGOJUAL_MAX_NEW_TOKENS_CHAT=160
JAGOJUAL_MAX_NEW_TOKENS_EVALUATE=512
